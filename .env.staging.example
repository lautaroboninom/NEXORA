# --- STAGING (PostgreSQL) ---

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
ALLOWED_ORIGINS=
FRONTEND_ORIGIN=
PUBLIC_WEB_URL=
TZ=America/Argentina/Buenos_Aires
BAJA_NOTIFY_RECIPIENTS=eduardo@sepid.com.ar

# Portal Sepid integration (read-only service token)
# Store the SHA-256 hash of the service token, not the plain token.
PORTAL_INTEGRATION_TOKEN_SHA256=
# Optional comma-separated IPs/CIDRs, e.g. Tailscale ranges. Empty means no IP restriction.
PORTAL_INTEGRATION_ALLOWED_IPS=

# PostgreSQL (staging)
DB_VENDOR=postgresql
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=servicio_tecnico
POSTGRES_USER=sepid
POSTGRES_PASSWORD=CHANGE_ME

# Frontend (build-time)
# Si se desea forzar URL del API en tiempo de build (por fuera del mismo origen):
# VITE_API_URL=http://api-staging:8000

# Presupuestos (PDFs) - opcional
QUOTES_HOST_DIR=./quotes

# Repuestos (costos)
REPUESTOS_COSTOS_HOST_DIR=C:/repuestos_costos
REPUESTOS_COSTOS_ROOT=/repuestos
REPUESTOS_COSTOS_FILE=/repuestos/COSTOS VIGENTES.xlsx

# Bejerman SDK
BEJERMAN_SYNC_ENABLED=0
BEJERMAN_WSDL_URL=
BEJERMAN_USER=
BEJERMAN_PASSWORD=
BEJERMAN_COMPANY=
BEJERMAN_WORKSTATION=
BEJERMAN_BRANCH=
BEJERMAN_SOURCE_DEPOSIT=STR
BEJERMAN_TARGET_DEPOSIT=STL
BEJERMAN_CLIENT_TARGET_DEPOSIT=STC
BEJERMAN_NUMERA_FLEX=S
BEJERMAN_STOCK_NUMERA_FLEX=N
BEJERMAN_STOCK_ENTRY_COMPROBANTE=RIS
BEJERMAN_STOCK_EXIT_COMPROBANTE=RSS
BEJERMAN_STOCK_TRANSFER_COMPROBANTE=TRA
BEJERMAN_STOCK_TRANSFER_TIPO_OPERACION=
BEJERMAN_ARTICLE_AUTO_MATCH=1
BEJERMAN_MAX_ATTEMPTS=8
BEJERMAN_REQUEST_TIMEOUT=30
